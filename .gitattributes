# Auto detect text files and perform LF normalization
* text=auto

# Keep SQL and docs with LF endings across Windows/Linux
*.sql  text eol=lf
*.md   text eol=lf

# Binary files - ignore completely from stats
*.pbix linguist-ignored
*.xlsx linguist-ignored
*.csv linguist-generated=true
*.pbit linguist-ignored

# Exclude entire folders from language detection
dashboards/** linguist-ignored
powerbi/** linguist-ignored

# Explicitly mark your actual languages
*.sql linguist-detectable=true
*.py linguist-detectable=true
